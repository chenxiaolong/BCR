    <!-- General preferences -->
    <string name="pref_call_recording_name">通話錄音</string>
    <string name="pref_call_recording_desc">錄製來電與播出通話。在背景錄音需要麥克風與通知權限。</string>

    <string name="pref_record_rules_name">自動錄音規則</string>
    <string name="pref_record_rules_desc">設定要自動錄製哪些通話。</string>

    <string name="pref_output_dir_name">輸出目錄</string>
    <string name="pref_output_dir_desc">選擇儲存錄音檔的目錄。長按以檔案管理員開啟。</string>

    <string name="pref_output_format_name">輸出格式</string>
    <string name="pref_output_format_desc">選擇錄音檔的編碼格式。</string>

    <string name="pref_min_duration_name">最小錄音檔長度</string>
    <plurals name="pref_min_duration_desc">
        <item quantity="one">保留長度至少 %d 秒的錄音檔。</item>
        <item quantity="other">保留長度至少 %d 秒的錄音檔。</item>
    </plurals>
    <string name="pref_min_duration_desc_zero">保留任何長度的錄音檔。</string>

    <string name="pref_write_metadata_name">寫入詮釋資料檔案</string>
    <string name="pref_write_metadata_desc">在音訊檔案旁建立包含通話詳細資料的 JSON 檔案。</string>

    <string name="pref_record_telecom_apps_name">錄製電信整合應用程式</string>
    <string name="pref_record_telecom_apps_desc">錄製整合 Android 電信系統的第三方應用程式的通話。這種通話的錄音檔很可能無聲。</string>

    <string name="pref_record_dialing_state_name">錄製接通前的通話</string>
    <string name="pref_record_dialing_state_desc">對於播出通話，撥號開始時就馬上開始錄音，而非等待接通。</string>

    <string name="pref_notification_open_dir_name">從通知開啟目錄</string>
    <string name="pref_notification_open_dir_desc">按下錄音完成通知時，開啟輸出目錄而非錄音檔。</string>

    <string name="pref_show_launcher_icon_name">顯示啟動器圖示</string>
    <string name="pref_show_launcher_icon_desc">如果隱藏啟動器圖示，播打 <b>*#*#BCR#*#*</b> 開啟應用程式。</string>

    <!-- About "preference" -->
    <string name="pref_version_name">版本</string>

    <!-- Debug preferences -->
    <string name="pref_force_direct_boot_name">強制直接啟動模式</string>
    <string name="pref_force_direct_boot_desc">假裝裝置處於第一次解鎖前的狀態，用於測試。</string>

    <string name="pref_migrate_direct_boot_name">遷移直接啟動錄音檔</string>
    <string name="pref_migrate_direct_boot_desc">遷移第一次解鎖前錄製的錄音檔。通常在第一次解鎖後會自動執行。</string>

    <string name="pref_save_logs_name">儲存紀錄檔</string>
    <string name="pref_save_logs_desc">將 logcat 紀錄檔儲存到檔案。</string>

