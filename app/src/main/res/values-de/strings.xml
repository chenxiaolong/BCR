    <string name="pref_call_recording_desc">Eingehende und ausgehende Anrufe aufnehmen. Berechtigungen für Mikrofon und Benachrichtigung werden benötigt, um Anrufaufnahmen im Hintergrund zu erstellen.</string>

    <string name="pref_record_rules_name">Regeln für automatische Aufnahmen</string>
    <string name="pref_record_rules_desc">Konfigurieren, welche Anrufe automatisch aufgenommen werden sollen.</string>

    <string name="pref_output_dir_name">Ausgabeverzeichnis</string>
    <string name="pref_output_dir_desc">Verzeichnis für Aufnahmen auswählen. Lange drücken, um im Dateimanager zu öffnen.</string>

