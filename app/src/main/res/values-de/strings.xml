    <string name="pref_record_dialing_state_name">Anrufe vor Verbindung aufnehmen</string>
    <string name="pref_record_dialing_state_desc">Aufnahme bei ausgehenden Anrufen starten, sobald mit dem Wählen begonnen wird, anstatt zu warten, bis der Anruf verbunden ist.</string>

